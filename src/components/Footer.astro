---
interface Props {
  footerText: string;
  email: string;
  vk: string;
  whatsapp: string;
  telegram: string;
}
const { footerText, email, vk, whatsapp, telegram } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="bg-primary py-10 px-6 text-center">
  <div class="max-w-site mx-auto">
    <p class="text-white/70 text-[0.9rem] mb-5">
      &copy; {year} {footerText}
    </p>
    <div class="flex justify-center gap-4">
      <a href={`mailto:${email}`} aria-label="Email" class="social-icon">
        <i class="fas fa-envelope"></i>
      </a>
      <a href={vk} target="_blank" rel="noopener" aria-label="VK" class="social-icon">
        <i class="fab fa-vk"></i>
      </a>
      <a href={whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp" class="social-icon">
        <i class="fab fa-whatsapp"></i>
      </a>
      <a href={telegram} target="_blank" rel="noopener" aria-label="Telegram" class="social-icon">
        <i class="fab fa-telegram"></i>
      </a>
    </div>
  </div>
</footer>

<style>
  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.15rem;
    text-decoration: none;
    transition: background 0.25s ease, color 0.25s ease, transform 0.25s ease;
  }
  .social-icon:hover {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
    transform: translateY(-3px);
  }
</style>
