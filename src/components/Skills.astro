---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: CollectionEntry<'skills'>[];
}
const { entries } = Astro.props;

const rendered = await Promise.all(
  entries.map(async (entry) => ({
    data: entry.data,
    Content: (await render(entry)).Content,
  }))
);
---
<section id="skills" class="py-24 px-4 bg-surface md:py-16">
  <div class="w-[90%] max-w-site mx-auto">
    <h2 class="text-[2rem] font-bold text-center text-primary mb-8 fade-in sm:text-[1.6rem]">
      Как проходит занятие
    </h2>
    <div class="grid grid-cols-2 gap-6 md:grid-cols-1">
      {rendered.map(({ data, Content }, i) => (
        <div
          class={`bg-white rounded-2xl p-8 border border-site-border shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md fade-in ${
            i === rendered.length - 1 && rendered.length % 2 !== 0
              ? 'col-span-2 max-w-[calc(50%-0.75rem)] mx-auto md:col-span-1 md:max-w-full'
              : ''
          }`}
        >
          <div class="w-14 h-14 rounded-xl bg-surface flex items-center justify-center mb-5">
            <i class={`fas ${data.icon} text-2xl text-accent`}></i>
          </div>
          <h3 class="text-lg font-semibold text-primary mb-3">{data.title}</h3>
          <div class="skill-body text-sm text-site-muted leading-relaxed">
            <Content />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
