---
interface Props {
  siteTitle: string;
  subtitle: string;
}
const { siteTitle, subtitle } = Astro.props;
---
<div class="relative flex flex-col items-center justify-center text-center z-[1] max-w-site w-full px-6 py-0 mx-auto">
  <!-- Flip card avatar -->
  <div class="hero-avatar w-[220px] h-[220px] perspective-[1000px] mx-auto mb-8">
    <div class="hero-avatar-flip relative w-full h-full [transform-style:preserve-3d] transition-transform duration-700 rounded-full hover:[transform:rotateY(180deg)]">
      <div class="absolute inset-0 rounded-full overflow-hidden backface-hidden border-4 border-white/30 shadow-lg bg-white">
        <img src="/assets/img/logomin.jpg" alt="Mighty English" class="w-full h-full object-contain p-3" />
      </div>
      <div class="absolute inset-0 rounded-full overflow-hidden backface-hidden border-4 border-white/30 shadow-lg bg-primary [transform:rotateY(180deg)]">
        <img src="/assets/img/me-none-bg.jpg" alt="Рудольф Ладнер" class="w-full h-full object-cover" />
      </div>
    </div>
  </div>

  <!-- Text -->
  <div class="text-white">
    <h1 class="text-[clamp(2.5rem,6vw,4rem)] font-bold tracking-[-0.03em] leading-[1.1] mb-4 text-white">
      {siteTitle}
    </h1>
    <p class="text-[clamp(1rem,2.5vw,1.25rem)] text-white/85 font-light mb-8 max-w-[520px] mx-auto">
      {subtitle}
    </p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a href="#about" class="btn-outline inline-block px-7 py-3 rounded-full font-medium border-2 border-white/70 text-white bg-transparent transition-all duration-200 hover:bg-white/15 hover:border-white hover:-translate-y-0.5 no-underline">
        Узнать больше
      </a>
      <a href="#contact" class="btn-primary inline-block px-7 py-3 rounded-full font-medium bg-white text-primary border-2 border-white transition-all duration-200 hover:bg-surface hover:-translate-y-0.5 hover:shadow-md no-underline">
        Записаться
      </a>
    </div>
  </div>
</div>

<!-- Scroll arrow -->
<a
  href="#about"
  class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/60 text-xl z-[1] transition-colors duration-200 hover:text-white animate-bounce-slow"
  aria-label="Прокрутить вниз"
>
  <i class="fas fa-chevron-down"></i>
</a>

<style>
  .backface-hidden {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  .perspective-\[1000px\] {
    perspective: 1000px;
  }
</style>
