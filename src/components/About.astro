---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: CollectionEntry<'about'>[];
}
const { entries } = Astro.props;

const rendered = await Promise.all(
  entries.map(async (entry) => ({
    data: entry.data,
    Content: (await render(entry)).Content,
  }))
);
---
<section id="about" class="py-24 px-4 bg-white md:py-16">
  <div class="w-[90%] max-w-site mx-auto">
    {rendered.map(({ data, Content }) => (
      <div class="max-w-[780px] mx-auto mb-16 last:mb-0 fade-in">
        <h2 class="relative text-[1.75rem] font-bold text-primary mb-4 pb-3">
          {data.title}
          <span class="absolute bottom-0 left-0 w-12 h-[3px] bg-accent rounded-sm"></span>
        </h2>
        <div class="about-content text-[1.05rem] leading-[1.8] text-site-text">
          <Content />
        </div>
      </div>
    ))}
  </div>
</section>
